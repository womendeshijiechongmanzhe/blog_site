include ../mixins/article-sort.pug

- const tags = site.tags.sort(page.orderby || 'name', page.order || 1)
.knowledge-filter
  a.knowledge-filter-item.active(href=url_for(config.tag_dir) + '/')
    span 全部
    em= site.posts.length
  each tag in tags.toArray()
    a.knowledge-filter-item(href=url_for(tag.path))
      span= tag.name
      em= tag.length

details.knowledge-section-list
  summary.article-sort-title.knowledge-section-summary
    span 全部文章
    i.fas.fa-chevron-down(aria-hidden='true')
  .knowledge-section-content
    if site.posts.length
      +articleSort(site.posts.sort('-date'))
    else
      .article-sort-empty 暂时还没有文章
